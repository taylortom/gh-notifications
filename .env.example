# Required: GitHub Personal Access Token with `notifications` and `repo` scopes
GH_NOTIFICATIONS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: Comma-separated list of allowed bearer tokens for API clients
API_TOKENS=my-secret-token-1,my-secret-token-2

# Optional
PORT=3000
POLL_INTERVAL=60
OPEN_STATE_TTL=300
